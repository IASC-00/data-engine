# Data Engine — Environment Variables
# Copy to .env and fill in your keys. All services have free tiers.

# OpenCorporates (free, higher rate limits with key)
# Get free key at: https://opencorporates.com/api_accounts/new
OPENCORPORATES_API_KEY=

# Foursquare Places API (1,000 calls/day free, no card required)
# Get key at: foursquare.com/developers
FOURSQUARE_API_KEY=your_foursquare_key_here

# Hunter.io (25 lookups/month free — last-resort email fallback)
# Get key at: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_key_here

# Apollo.io (50 email credits/month free)
# Get key at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your_apollo_key_here

# Firecrawl (free tier — 500 credits/month)
# Get key at: https://firecrawl.dev
FIRECRAWL_API_KEY=your_firecrawl_key_here
FIRECRAWL_BIN=/path/to/firecrawl

# OpenRouter (free tier — for AI enrichment features)
# Get key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_key_here

# AppForge integration (optional — local only)
APPFORGE_URL=http://localhost:5001
